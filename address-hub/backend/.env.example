# Copy to .env and adjust as needed.

# Port the Express server listens on.
PORT=3001

# Path to the SQLite database file (resolved relative to repo root).
DATABASE_PATH=./data/addresses.db

# CORS origin for the frontend dev server.
CORS_ORIGIN=http://localhost:3000

# --- Optional API credentials for platforms that expose an API ---
# Leave blank to disable API-driven updates; the UI will fall back to manual
# instructions for that platform.

USPS_API_KEY=
USPS_API_SECRET=

PNC_CLIENT_ID=
PNC_CLIENT_SECRET=

CHASE_CLIENT_ID=
CHASE_CLIENT_SECRET=
